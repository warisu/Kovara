{
  "name": "Kovara-sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript client for KovaraContract on Stellar",
  "homepage": "https://github.com/Epta-Node/Kovara#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Epta-Node/Kovara.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Epta-Node/Kovara/issues"
  },
  "license": "Apache-2.0",
  "author": "Kovara Contributors",
  "keywords": [
    "stellar",
    "soroban",
    "Kovara",
    "sdk",
    "typescript",
    "client"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "build": "tsc --outDir dist --declaration --declarationMap --sourceMap --module commonjs --target ES2020 --moduleResolution node --esModuleInterop --skipLibCheck",
    "docs": "typedoc --out docs src/index.ts --tsconfig tsconfig.json",
    "test": "jest",
    "test:e2e": "jest --testPathPattern=e2e.test.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typedoc": "^0.26.11",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
